# --- Photo storage backend ---
# "local" (default) reads from public/photos, "pcloud" reads from pCloud.
# Server-only, so a plain PHOTO_SOURCE works (no NEXT_PUBLIC_ needed) and is
# read at runtime. NEXT_PUBLIC_PHOTO_SOURCE is also honored.
PHOTO_SOURCE=pcloud

# --- pCloud credentials (email + password auth) ---
PCLOUD_EMAIL=your-pcloud-email@example.com
PCLOUD_PASSWORD=your-pcloud-password
# Optional: a pre-fetched persistent auth token. When set, the app skips the
# login call entirely (avoids device-verification / 2FA prompts on a server).
# Generate it once by running `node scripts/test-pcloud.mjs` and copying the
# token it prints, or call https://api.pcloud.com/login?getauth=1.
# PCLOUD_AUTH_TOKEN=your-persistent-token
# Optional: one-time verification/2FA code if pCloud prompts for one.
# PCLOUD_CODE=123456
# Numeric folder id that holds the photo collections (each subfolder is a
# collection). Use "0" for the pCloud root, or the id of a dedicated folder.
PCLOUD_ROOT_FOLDERID=0
# Optional: override the pCloud API host (e.g. eapi.pcloud.com for EU).
# PCLOUD_API_HOST=https://eapi.pcloud.com

# --- App auth / payments ---
AUTH_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password

# Optional: override disk cache location for downloaded images
# PHOTO_CACHE_DIR=/tmp/lumen-photo-cache

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         String     @default("user")
  paid         Boolean    @default(false)
  createdAt    DateTime   @default(now())
  favorites    Favorite[]
  orders       Order[]

  @@index([email])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  photoId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, photoId])
  @@index([userId])
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  status    String   @default("pending") // pending, paid, fulfilled
  stripeId  String?  @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "paths": {
      "@lumen/shared": ["../../libs/shared/src"]
    }
  },
  "include": ["src", "../../libs/shared/src"],
  "references": [{ "path": "../../libs/shared" }]
}

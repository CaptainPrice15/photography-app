{
  "framework": "angular",
  "buildCommand": "pnpm ng:build",
  "outputDirectory": "apps/lumen/dist/lumen",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/api-handler" },
    { "source": "/(.*)", "destination": "/api/ssr-handler" }
  ],
  "functions": {
    "api/api-handler.mts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/ssr-handler.mts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
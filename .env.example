# --- Photo storage backend ---
# "local" (default) reads from public/photos, "filen" reads from Filen cloud.
NEXT_PUBLIC_PHOTO_SOURCE=filen

# --- Filen credentials (email + password auth) ---
FILEN_EMAIL=your-filen-email@example.com
FILEN_PASSWORD=your-filen-password
# FILEN_TWO_FACTOR_CODE=123456

# --- App auth / payments ---
AUTH_SECRET=replace-with-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password

# Optional: override disk cache location for decrypted images
# FILEN_CACHE_DIR=/tmp/lumen-filen-cache
